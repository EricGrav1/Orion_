# Supabase Configuration
# Copy this file to .env.local and fill in your actual values
# Get these values from your Supabase project settings at https://app.supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_BASE_URL=
# Optional OAuth override (useful in dev if accessing via LAN IP).
VITE_OAUTH_REDIRECT_TO=
# Optional dev override to bypass trial gating for any authenticated user.
VITE_FORCE_PRO_MODE=
# Optional dev bypass: comma-separated emails treated as Pro/active for trial gating.
VITE_PRO_ACCESS_EMAILS=
# Optional: Backend endpoint that returns a structured outline
# Expected payload: POST { preferredBlueprint, document } -> { outline }
VITE_AI_IMPORT_PIPELINE_ENDPOINT=

# Stripe (Supabase Edge Functions)
# These are secrets. Configure them in Supabase function env vars, not in your Vite .env.local.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_CREATOR=
SITE_URL=
# Optional comma-separated allowlist for checkout/portal redirect origins.
ALLOWED_ORIGINS=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Team invite delivery (Supabase Edge Function: team-invite-send)
RESEND_API_KEY=
INVITE_FROM_EMAIL=
APP_BASE_URL=

# LMS integration encryption (Supabase Edge Functions: lms-integrations-*)
LMS_CREDENTIALS_ENCRYPTION_KEY=
